DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Ace Music (ACE-Step v1.5) cloud API ─────────────────────────────────────
# The real music-generation model. Used server-side only by src/lib/ai/ace-client.ts.
# Cloud API base (OpenAI-compatible /v1/chat/completions endpoint).
ACE_API_BASE=https://api.acemusic.ai
# API key issued at https://acemusic.ai/api-key
ACE_API_KEY=7ee912d584474aa48fc5d10b347cfd58
# Model id returned by GET /v1/models
ACE_MODEL=acemusic/acestep-v1.5-turbo
# Max wall-clock seconds for a single generation request (the model is
# synchronous — one HTTP call returns the full base64 MP3). 300s is a safe
# ceiling that covers 60s+ tracks with thinking enabled.
ACE_REQUEST_TIMEOUT_MS=300000
