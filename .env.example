# Database
DATABASE_URL=file:/home/z/my-project/db/custom.db

# Ace Music API
ACE_API_BASE=https://api.acemusic.ai
ACE_API_KEY=your-key
ACE_MODEL=acemusic/acestep-v1.5-turbo
ACE_REQUEST_TIMEOUT_MS=300000

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
NEXT_PUBLIC_GITHUB_ENABLED=false

# Redis (for BullMQ queue + Socket.io pub/sub) — optional in dev
REDIS_URL=

# Upstash rate limiting (optional — falls back to in-memory)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# S3 / R2 storage (optional — falls back to inline DB storage)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=spotibot
S3_REGION=auto
S3_PUBLIC_URL=

# ACE-Step self-hosted API (optional — falls back to cloud API)
ACE_STEP_API=

# Socket.io server
NEXT_PUBLIC_SOCKET_URL=

# Discord bot
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
