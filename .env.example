# Database (SQLite for local dev; switch to postgresql for production)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# ─── Ace Music (ACE-Step v1.5) cloud API ─────────────────────────────────────
ACE_API_BASE=https://api.acemusic.ai
ACE_API_KEY=your-api-key-here
ACE_MODEL=acemusic/acestep-v1.5-turbo
ACE_REQUEST_TIMEOUT_MS=300000

# ─── NextAuth.js ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
# The base URL of the app. In dev: http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
# GitHub OAuth (optional — create at https://github.com/settings/developers)
# Leave empty to disable GitHub sign-in (email/password still works)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Set to "true" to show the GitHub button on the sign-in page
NEXT_PUBLIC_GITHUB_ENABLED=false
