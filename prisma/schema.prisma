// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A registered user. Created on sign-up (email/password) or on first OAuth
// sign-in (GitHub). Owns songs, playlists, history, and follow relationships.
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String? // null for OAuth-only users
  image     String?
  // Public profile fields (Phase 3)
  username  String?    @unique // lowercase, alphanumeric + hyphens, 3–20 chars
  bio       String? // free-form bio, max 200 chars
  isAdmin   Boolean  @default(false) // admin flag for admin panel access
  createdAt DateTime   @default(now())

  songs     Song[]
  playlists Playlist[]
  history   ListeningHistory[]
  followers Follow[]   @relation("following") // people who follow me
  following Follow[]   @relation("follower")  // people I follow
  notifications Notification[]
}

// A generated song / track produced by the AI music pipeline.
model Song {
  id          String         @id @default(cuid())
  title       String
  prompt      String
  lyrics      String
  genre       String
  mood        String
  style       String
  voice       String   @default("en")
  audioData   Bytes
  audioFormat String   @default("mp3")
  durationMs  Int      @default(0)
  coverData   Bytes?
  coverFormat String   @default("png")
  bpm         Int?
  keyScale    String?
  timeSig     String?
  seed        BigInt?
  liked       Boolean  @default(false)
  // When true, the track appears in the public Discover feed (Phase 3).
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())

  // ─── Async generation pipeline (Phase P1) ────────────────────────────────
  // Lifecycle: "generating" → "ready" (success) | "failed" (error).
  // Defaults to "ready" so all pre-existing synchronous songs are playable.
  status       String   @default("ready") // "generating" | "ready" | "failed"
  // BullMQ job id when this song is being produced asynchronously. Cleared
  // (set to null) once the job reaches a terminal state and the song is ready.
  jobId        String?
  // Last error message when status = "failed". Null otherwise.
  errorMessage String?
  // Denormalized play counter (incremented on each play event).
  playCount    Int      @default(0)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  playlistItems PlaylistSong[]
  history       ListeningHistory[]

  @@index([createdAt])
  @@index([liked])
  @@index([ownerId])
  @@index([isPublic, createdAt])
  @@index([status])
  @@index([jobId])
}

// A BullMQ generation job record. Persisted alongside the queue so that the
// API layer can serve job status / progress polling even when the Redis-backed
// queue is unavailable (the synchronous fallback still writes a row here for
// observability). One row per enqueued job; the `jobId` field mirrors the
// BullMQ job id and is unique.
model GenerationJob {
  id        String   @id @default(cuid())
  jobId     String   @unique
  status    String   @default("queued") // "queued" | "active" | "completed" | "failed"
  progress  Float    @default(0) // 0..100
  userId    String
  prompt    String
  genre     String
  mood      String
  style     String
  params    String? // JSON-encoded extra params (voice, duration, seed, ...)
  error     String? // populated when status = "failed"
  songId    String? // populated when status = "completed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

// A user-created playlist (Spotify-style).
model Playlist {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  items     PlaylistSong[]

  @@index([createdAt])
  @@index([ownerId])
}

// Join table between Playlist and Song with an explicit `position` field.
model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, position])
}

// A single "user played this song" event. Used to build the listening history.
model ListeningHistory {
  id        String   @id @default(cuid())
  userId    String
  songId    String
  playedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([userId, playedAt])
}

// Follow relationship: follower follows following (Phase 3 social).
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

// In-app notification (Phase 4). Types: follow, like, generation, system.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, read, createdAt])
}
