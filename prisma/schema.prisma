// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A generated song / track produced by the AI music pipeline.
// Audio bytes + AI-generated cover art are stored directly in SQLite
// (small files, demo-scale) and streamed back to the client via the
// /api/audio/[id] and /api/cover/[id] routes.
model Song {
  id          String         @id @default(cuid())
  title       String
  prompt      String
  lyrics      String
  genre       String
  mood        String
  style       String
  voice       String   @default("en")
  audioData   Bytes
  audioFormat String   @default("mp3")
  durationMs  Int      @default(0)
  // AI-generated square cover art (PNG bytes). Nullable so cover generation
  // failures don't lose the song — the UI falls back to a gradient cover.
  coverData   Bytes?
  coverFormat String   @default("png")
  // Musical attributes surfaced by the Ace Music model.
  bpm         Int?
  keyScale    String?
  timeSig     String?
  // The seed used for generation (enables reproducibility display in the UI).
  seed        BigInt?
  liked       Boolean  @default(false)
  createdAt   DateTime @default(now())

  playlistItems PlaylistSong[]

  @@index([createdAt])
  @@index([liked])
}

// A user-created playlist (Spotify-style). Playlists group songs in a
// user-defined order. The cover is a gradient derived from the playlist name
// (no AI cover for playlists — keeps the feature lightweight).
model Playlist {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())
  items     PlaylistSong[]

  @@index([createdAt])
}

// Join table between Playlist and Song with an explicit `position` field so
// tracks keep their user-defined order inside a playlist.
model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, position])
}
