// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for local dev. Switch to postgresql for production (Neon/Supabase):
  //   provider = "postgresql"
  //   url      = env("DATABASE_URL")
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// A registered user. Created on sign-up (email/password) or on first OAuth
// sign-in (GitHub). Owns songs and playlists.
model User {
  id        String     @id @default(cuid())
  email     String     @unique
  name      String?
  password  String? // null for OAuth-only users
  image     String?
  createdAt DateTime   @default(now())
  songs     Song[]
  playlists Playlist[]
}

// A generated song / track produced by the AI music pipeline.
model Song {
  id          String         @id @default(cuid())
  title       String
  prompt      String
  lyrics      String
  genre       String
  mood        String
  style       String
  voice       String   @default("en")
  audioData   Bytes
  audioFormat String   @default("mp3")
  durationMs  Int      @default(0)
  coverData   Bytes?
  coverFormat String   @default("png")
  bpm         Int?
  keyScale    String?
  timeSig     String?
  seed        BigInt?
  liked       Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Owner of this song. Required — every song belongs to a user.
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  playlistItems PlaylistSong[]

  @@index([createdAt])
  @@index([liked])
  @@index([ownerId])
}

// A user-created playlist (Spotify-style).
model Playlist {
  id        String         @id @default(cuid())
  name      String
  createdAt DateTime       @default(now())

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  items     PlaylistSong[]

  @@index([createdAt])
  @@index([ownerId])
}

// Join table between Playlist and Song with an explicit `position` field.
model PlaylistSong {
  id         String   @id @default(cuid())
  playlistId String
  songId     String
  position   Int
  addedAt    DateTime @default(now())

  playlist Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  song     Song     @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@unique([playlistId, songId])
  @@index([playlistId, position])
}
